JWT_SECRET=your_jwt_secret_here

# ── MikroTik (single-site legacy / default) ──
# After running mikrotik-setup.rsc, MikroTik LAN is 192.168.100.1
# Update this to your MikroTik's IP after setup
MIKROTIK_HOST=192.168.100.1
MIKROTIK_USER=admin
MIKROTIK_PASS=password
MIKROTIK_PORT=8728

# ── Multi-site config (add as many sites as needed) ──
# SITE_1_HOST=192.168.100.1
# SITE_1_NAME=Site Name (e.g. Westlands)
# SITE_1_USER=admin
# SITE_1_PASS=password
#
# SITE_2_HOST=192.168.100.1
# SITE_2_NAME=Kilimani
# SITE_2_USER=admin
# SITE_2_PASS=password

# ── Database ──
DB_USER=postgres
DB_HOST=localhost
DB_NAME=internet_distribution
DB_PASSWORD=postgres
DB_PORT=5432